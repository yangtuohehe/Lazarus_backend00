<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.lazarus_backend00.dao.ParameterDao">

    <resultMap id="BaseResultMap" type="com.example.lazarus_backend00.infrastructure.persistence.entity.ParameterEntity">
        <id column="id" property="id" />
        <result column="interfaceId" property="interfaceId" />
        <result column="ioType" property="ioType" />
        <result column="tensorOrder" property="tensorOrder" />
        <result column="originPoint" property="originPoint" typeHandler="com.example.lazarus_backend00.infrastructure.config.JtsGeometryTypeHandler"/>
        <result column="coverageGeom" property="coverageGeom" typeHandler="com.example.lazarus_backend00.infrastructure.config.JtsGeometryTypeHandler"/>
        <result column="oTimeStep" property="oTimeStep" />
        <result column="createdAt" property="createdAt" />
        <result column="updatedAt" property="updatedAt" />
    </resultMap>

    <insert id="insert"
            parameterType="com.example.lazarus_backend00.infrastructure.persistence.entity.ParameterEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO parameter (
            interface_id,
            io_type,
            origin_point,
            coverage_geom,
            tensor_order,
            o_time_step,
            created_at,
            updated_at
        )
        VALUES (
                   #{interfaceId},
                   #{ioType},
                   #{originPoint},
                   #{coverageGeom},
                   #{tensorOrder},
                   #{oTimeStep},
                   #{createdAt},
                   #{updatedAt}
               )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
            id,
            interface_id  AS interfaceId,
            io_type       AS ioType,
            tensor_order  AS tensorOrder,

            ST_AsBinary(origin_point)  AS originPoint,
            ST_AsBinary(coverage_geom) AS coverageGeom,
            o_time_step AS oTimeStep,

            created_at    AS createdAt,
            updated_at    AS updatedAt
        FROM parameter
        WHERE id = #{id}
    </select>

    <select id="selectByCondition" parameterType="com.example.lazarus_backend00.infrastructure.persistence.entity.ParameterEntity" resultMap="BaseResultMap">
        SELECT
        id,
        interface_id  AS interfaceId,
        io_type       AS ioType,
        tensor_order  AS tensorOrder,

        ST_AsBinary(origin_point)  AS originPoint,
        ST_AsBinary(coverage_geom) AS coverageGeom,
        o_time_step AS oTimeStep,

        created_at    AS createdAt,
        updated_at    AS updatedAt
        FROM parameter
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="interfaceId != null">
                AND interface_id = #{interfaceId}
            </if>
            <if test="ioType != null and ioType != ''">
                AND io_type = #{ioType}
            </if>
            <if test="tensorOrder != null and tensorOrder != ''">
                AND tensor_order = #{tensorOrder}
            </if>

            <if test="coverageGeom != null">
                AND ST_Intersects(coverage_geom, #{coverageGeom})
            </if>
            <if test="oTimeStep != null">
                AND o_time_step = #{oTimeStep}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>